{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/block-dangerous-git.sh",
            "statusMessage": "Checking git safety",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
