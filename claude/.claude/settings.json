{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": false,
  "cleanupPeriodDays": 365,
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-sonnet-4-6",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "USE_BUILTIN_RIPGREP": "0",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "30000",
    "BASH_MAX_TIMEOUT_MS": "300000",
    "BASH_MAX_OUTPUT_LENGTH": "50000",
    "MCP_TIMEOUT": "15000",
    "MCP_TOOL_TIMEOUT": "60000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(stow *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git show *)",
      "Bash(shellcheck *)",
      "Bash(shfmt *)",
      "Bash(zsh -n *)",
      "Bash(* --help)",
      "Bash(* --version)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",
      "Bash(git rebase*)",
      "Bash(git commit --amend*)",
      "Bash(git rm *)",
      "Bash(git gc*)",
      "Bash(git prune*)",
      "Bash(git reflog expire*)",
      "Bash(git update-ref*)",
      "Bash(git restore*)",
      "Bash(git checkout * -- *)",

      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Bash(dd *)",

      "Bash(wget *|bash*)",
      "Bash(wget *| bash*)",
      "Bash(wget *|sh*)",
      "Bash(wget *| sh*)",
      "Bash(curl *|bash*)",
      "Bash(curl *| bash*)",
      "Bash(curl *|sh*)",
      "Bash(curl *| sh*)",

      "Edit(~/.bashrc)",
      "Edit(~/.bash_profile)",
      "Edit(~/.zshrc)",
      "Edit(~/.zprofile)",
      "Edit(~/.profile)",
      "Edit(~/.ssh/**)",

      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.npm/**)",
      "Read(~/.pypirc)",
      "Read(~/.gem/credentials)",
      "Read(~/Library/Keychains/**)",
      "Read(~/Library/Application Support/**/metamask*/**)",
      "Read(~/Library/Application Support/**/electrum*/**)",
      "Read(~/Library/Application Support/**/exodus*/**)",
      "Read(~/Library/Application Support/**/phantom*/**)",
      "Read(~/Library/Application Support/**/solflare*/**)"
    ]
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous-git.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true
  },
  "forceLoginMethod": "claudeai",
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "autoInstallIdeExtension": false
}
